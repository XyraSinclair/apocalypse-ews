PORT=3030
EWS_PUBLIC_URL=http://127.0.0.1:3030/
EWS_NOTIFICATION_URL=http://127.0.0.1:3030/
EWS_RSS_URL=http://127.0.0.1:3030/rss.xml

# Leave blank to use local Express-served snapshots:
# /dashboard.json, /military-dashboard.json, /untracked-dashboard.json
VITE_DASHBOARD_URL=
VITE_MILITARY_DASHBOARD_URL=
VITE_UNTRACKED_DASHBOARD_URL=
CLOUDFLARE_PAGES_PROJECT=apocalypse-ews
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
EWS_SMOKE_URL=

EWS_PUBLISHED_DIR=

# Optional Telegram emergency alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_CHANNEL=

# Required paid notification backend secrets for production Pages deploys.
APP_BASE_URL=http://127.0.0.1:3030
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRODUCT_ID=
STRIPE_PRICE_ID=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=Apocalypse EWS
SENDGRID_WEBHOOK_PUBLIC_KEY=
SENDGRID_WEBHOOK_URL=
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
# Configure at least one Telnyx sender source.
TELNYX_NUMBER=
TELNYX_FROM_PHONE=
TELNYX_MESSAGING_PROFILE_ID=
# Required for Cloudflare Pages internal alert ingestion and post-deploy smoke checks.
INTERNAL_ALERT_TOKEN=
EWS_ALERT_EVENTS_WEBHOOK_URL=https://your-pages-domain.example/api/internal/alert-events
EWS_ALERT_BRIDGE_STATUS_PATH=
NOTIFICATION_HASH_SECRET=
NOTIFICATION_ENCRYPTION_KEY=


# Alert fanout controls. Defaults send one subscriber batch per invocation; the maintenance worker resumes queued batches every minute.
LEVEL5_SUBSCRIBER_BATCH_SIZE=500
ALERT_EVENT_MAX_BATCHES_PER_INVOCATION=1
ALERT_PROCESSING_STALE_MS=900000
ALERT_FANOUT_LEASE_MS=1800000
# Required for production Pages deploy smoke: both providers must accept a live test message.
EWS_SMOKE_TEST_EMAIL=
EWS_SMOKE_TEST_PHONE=